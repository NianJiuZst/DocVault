# ============================================
# DocVault Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# For local development, docker-compose.dev.yml reads these too.

# ---- Database ----
# PostgreSQL connection string (Docker: postgres:5432, Local: localhost:5432)
DATABASE_URL=postgresql://docvault:docvault123@localhost:5432/docvault

# ---- Server ----
PORT=3001

# ---- JWT ----
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_at_least_32_characters

# ---- GitHub OAuth App ----
# Create at: https://github.com/settings/applications/new
# Authorization callback URL: http://localhost:3001/auth/github/callback (dev)
#                                     or your production URL (prod)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3001/auth/github/callback

# ---- Frontend ----
# URL of the frontend for CORS (backend) and API calls (frontend)
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth callback URL (frontend)
AUTH_CALLBACK_URL=http://localhost:3001/auth/github/callback
