# Database
DATABASE_URL="postgresql://docvault:docvault123@localhost:5432/docvault"

# GitHub OAuth
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_REDIRECT_URI="http://localhost:3001/auth/github/callback"

# JWT
JWT_SECRET="your_jwt_secret_at_least_32_characters_long"

# Frontend URL (for redirect after GitHub OAuth)
FRONTEND_URL="http://localhost:3000"

# Backend Port (optional, defaults to 3000)
PORT=3001
